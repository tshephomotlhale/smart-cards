# Database
POSTGRES_USER=smartcards
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=smartcards
DATABASE_URL=postgresql+asyncpg://smartcards:change_me_in_production@db:5432/smartcards

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change_me_to_a_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Africa's Talking (USSD + SMS)
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
AT_SHORTCODE=*123#
AT_SENDER_ID=SmartCard

# App
APP_ENV=development
APP_NAME=Smart Patient Card System
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
